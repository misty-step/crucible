{
  "schema_version": "crucible.eval_spec.v1",
  "id": "commit-message-quality-v1",
  "task": "commit-message-quality",
  "inputs": "30 diffs \u2014 23 real commits mined from five fleet repos (curated so the Conventional Commits type is inferable from the diff alone) + 7 synthetic pure-refactor diffs (no real refactor: commits exist in fleet history). Each task's diff is a committed fixture file; a known-good reference message per task lives beside it and is verified against the task's own grader.",
  "outputs": "One generated Conventional Commits message per diff, graded by a per-task regex that pins the defensible type-set (alternation where two types are expert-defensible), requires a subject, and requires a body.",
  "graders": {
    "graders": [
      {
        "id": "conventional_commit_shape",
        "kind": "deterministic"
      }
    ]
  },
  "aggregation": "proportion",
  "uncertainty": {
    "method": "wilson",
    "confidence": 0.95
  },
  "decision": "Which model/config should fleet agents use to write commit messages -- does it read the diff well enough to choose the right type, and does it keep the structural contract (subject + body)? Feeds routing; the faithfulness/why judge layer is v2 (needs the generate-then-judge runner).",
  "min_effect_of_interest": 0.3,
  "runner": {
    "kind": "prompt_benchmark",
    "corpus": {
      "source": "prompt_benchmark",
      "config": {
        "provider": "open_router",
        "model": "deepseek/deepseek-v4-flash",
        "system_prompt": "You write git commit messages in the Conventional Commits style. Given a unified diff, produce exactly one commit message: a subject line of the form `type(scope): summary` (scope optional) where type is the single most fitting of feat, fix, docs, refactor, perf, test, build, ci, chore; then a blank line; then a body of one or more sentences explaining what changed and why. Respond with ONLY the commit message text -- no code fences, no preamble, no quotes, no trailing commentary.",
        "credential_env": "OPENROUTER_API_KEY",
        "max_tokens": 2000,
        "temperature": 0
      },
      "tasks": [
        {
          "task_id": "fix-dialog-top-layer",
          "class": "fix",
          "context_file": "fixtures/commit-message-quality-v1/fix-dialog-top-layer.diff",
          "prompt": "The unified diff above is the complete change. Write exactly one Conventional Commits message for it.",
          "expectation": {
            "kind": "regex",
            "pattern": "^(fix)(\\([A-Za-z0-9._ -]+\\))?!?: .{3,}\\n\\n.+"
          }
        },
