index 72734f1..fac057b 100644
--- a/apps/cairn/static/app.css
+++ b/apps/cairn/static/app.css
@@ -210,6 +210,18 @@ dialog[open] #habit-form { animation: pop 0.3s var(--spring); }
 .cal-cell.off { opacity: 0.3; border-style: dashed; }
 .cal-cell.today { box-shadow: 0 0 0 3px var(--c-yellow); }
 .cal-cell.blank { border: 0; background: transparent; }
+/* cal month nav */
+.cal-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
+.cal-month-lbl { font-family: "Helvetica Neue", Arial, sans-serif; font-weight: 900; font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink); }
+.cal-nav-spacer { width: 30px; }
+.cal-nav-btn { width: 30px; height: 30px; border: 2.5px solid var(--ink); background: var(--surface); display: grid; place-items: center; cursor: pointer; flex: none; }
+.cal-nav-btn .ic { width: 16px; height: 16px; stroke-width: 2.8; }
+.cal-nav-btn:active { transform: translate(1px,1px); box-shadow: 1px 1px 0 var(--ink); }
+/* button reset for tappable cal cells */
+button.cal-cell { cursor: pointer; border: 2.5px solid var(--ink); padding: 0; font: inherit; color: inherit; }
+button.cal-cell:not(.off):hover { outline: 2px solid var(--accent); outline-offset: 1px; }
+button.cal-cell:active { transform: scale(0.88); }
+.cal-cell.future { cursor: default; }
 
 .ov-row { display: grid; grid-template-columns: 26px 1fr auto; align-items: center; gap: 9px; padding: 9px 0; border-bottom: 2px dotted var(--ink); }
 .ov-row .ic { width: 18px; height: 18px; color: var(--accent); }
