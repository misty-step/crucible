+/// Machine-readable read of the live stars store, so a remote publisher
+/// (`artifact_create.py`, the deck) can stamp `starred` onto its own copy of
+/// the registry without duplicating the stars file's on-disk format.
+async fn list_stars(State(state): State<AppState>) -> Response {
+    let starred = load_starred(&state.stars_path).await;
+    let body = serde_json::json!({ "starred": starred }).to_string();
+    (
+        StatusCode::OK,
+        [(header::CONTENT_TYPE, "application/json")],
+        body,
+    )
+        .into_response()
+}
